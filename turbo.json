{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": ["**/.env"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".output/**", ".tanstack/**", ".expo/**", "dist/**", "build/**", "lib/**"],
      "passThroughEnv": []
    },
    "clean": {
      "cache": false,
      "outputs": []
    },
    "dev": {
      "cache": false,
      "inputs": ["$TURBO_DEFAULT$", ".env"],
      "persistent": true
    },
    "start": {
      "cache": false
    },
    "test": {
      "cache": false
    },
    "topo": {
      "dependsOn": ["^topo"]
    },
    "typecheck": {
      "dependsOn": ["^topo"],
      "outputs": []
    }
  },
  "ui": "tui"
}
