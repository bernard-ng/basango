{
  "compilerOptions": {
    "jsx": "react-jsx",
    "noEmit": true,
    "paths": {
      "@basango/ui/*": ["../../packages/ui/src/*"],
      "#api/*": ["../api/src/*"],
      "#dashboard/*": ["./src/*"],
      "#db/*": ["../../packages/db/src/*"],
      "#domain/*": ["../../packages/domain/src/*"]
    }
  },
  "exclude": ["node_modules"],
  "extends": "@basango/tsconfig/base.json",
  "include": ["vite.config.ts", "**/*.ts", "**/*.tsx"]
}
